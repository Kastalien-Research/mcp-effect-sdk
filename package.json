{
  "name": "mcp-effect-sdk",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "check:conformance-evidence": "node scripts/check-conformance-evidence.mjs",
    "check:generated": "node scripts/generate-mcp.mjs --check",
    "check:generated-protocol-surfaces": "node scripts/check-generated-protocol-surfaces.mjs",
    "check:schema-fixtures": "node scripts/check-generated-schema-fixtures.mjs",
    "check:historical-mcp": "node scripts/check-historical-mcp-cleanup.mjs",
    "check:invariants": "node scripts/check-invariants.mjs",
    "check:sdk-workflow": "node scripts/check-sdk-workflow.mjs",
    "check:tasks": "node scripts/check-task-runtime.mjs",
    "conformance:run": "pnpm run build && node scripts/run-conformance-suite.mjs",
    "conformance:server": "pnpm run build && node scripts/run-conformance-server.mjs",
    "generate:mcp": "node scripts/generate-mcp.mjs",
    "test": "pnpm run verify",
    "verify": "node scripts/verify.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@effect/rpc": "^0.75.0",
    "@effect/schema": "^0.75.5",
    "effect": "4.0.0-beta.36"
  }
}
