{
  "name": "mcp-effect-sdk",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.11.1",
  "description": "",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./integrations/effect-platform": {
      "import": "./dist/integrations/EffectPlatform.js",
      "types": "./dist/integrations/EffectPlatform.d.ts"
    },
    "./transport/stdio": {
      "import": "./dist/transport/stdio.js",
      "types": "./dist/transport/stdio.d.ts"
    },
    "./transport/http": {
      "import": "./dist/transport/http.js",
      "types": "./dist/transport/http.d.ts"
    },
    "./deprecated": {
      "import": "./dist/deprecated.js",
      "types": "./dist/deprecated.d.ts"
    }
  },
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "check:conformance-evidence": "node scripts/check-conformance-evidence.mjs",
    "check:extensions": "node scripts/check-extension-boundary.mjs",
    "check:effect-foundation": "node scripts/check-effect-foundation.mjs",
    "check:generated": "node scripts/generate-mcp.mjs --check",
    "check:generated-protocol-surfaces": "node scripts/check-generated-protocol-surfaces.mjs",
    "check:schema-fixtures": "node scripts/check-generated-schema-fixtures.mjs",
    "check:historical-mcp": "node scripts/check-historical-mcp-cleanup.mjs",
    "check:invariants": "node scripts/check-invariants.mjs",
    "check:sdk-readiness": "node scripts/check-sdk-readiness-requirements.mjs",
    "check:sdk-runtime": "node scripts/check-sdk-runtime.mjs",
    "check:tier-protocol-features": "node scripts/check-tier-protocol-features.mjs",
    "check:ts-sdk-parity": "node scripts/check-ts-sdk-parity.mjs",
    "check:sdk-workflow": "node scripts/check-sdk-workflow.mjs",
    "check:tasks": "node scripts/check-task-runtime.mjs",
    "check:tier-operations": "node scripts/check-tier-operations.mjs",
    "check:type-fixtures": "node scripts/check-type-fixtures.mjs",
    "test:effect-foundation": "node --test test/foundation/effect-foundation.test.mjs",
    "test:wp2-review": "node --test test/foundation/wp2-review-regressions.test.mjs",
    "test:wp3-schema": "pnpm run build && node --test test/generation/wp3-schema-codecs.test.mjs",
    "test:wp3-protocol": "pnpm run build && node --test test/generation/wp3-protocol-metadata.test.mjs",
    "test:wp4-wire": "pnpm run build && node scripts/run-wp4-wire-suite.mjs",
    "test:wp4-dispatcher": "pnpm run build && node scripts/run-wp4-dispatcher-suite.mjs",
    "test:wp4-stdio": "pnpm run build && node scripts/run-wp4-stdio-suite.mjs",
    "test:wp4-http-metadata": "pnpm run build && node scripts/run-wp4-http-metadata-suite.mjs",
    "test:wp4-http-client": "pnpm run build && node scripts/run-wp4-http-client-suite.mjs",
    "test:wp4-http-server": "pnpm run build && node scripts/run-wp4-http-server-suite.mjs",
    "test:wp4-http": "pnpm run build && node scripts/run-wp4-http-suite.mjs",
    "test:wp4-transports": "pnpm run build && node scripts/run-wp4-transports-suite.mjs",
    "test:wp5a-result-metadata": "pnpm run build && node --test test/core/wp5-result-metadata.test.mjs",
    "test:wp5a-result-decoding": "pnpm run build && node --test test/client/wp5-result-decoding.test.mjs",
    "test:wp5a-types": "pnpm exec tsc -p test/types/wp5-core-result/tsconfig.json --noEmit",
    "test:wp5a": "pnpm run build && node --test test/core/wp5-result-metadata.test.mjs test/client/wp5-result-decoding.test.mjs && pnpm run test:wp5a-types",
    "test:wp5b-client-runtime": "pnpm run build && node --test test/client/wp5b-client-construction.test.mjs",
    "test:wp5b-client-types": "pnpm exec tsc -p test/types/wp5b-client-construction/tsconfig.json --noEmit",
    "test:wp5b-client": "pnpm run build && node --test test/client/wp5b-client-construction.test.mjs && pnpm run test:wp5b-client-types",
    "test:wp5b-server-runtime": "pnpm run build && node --test test/server/wp5b-server-construction.test.mjs",
    "test:wp5b-server-types": "pnpm exec tsc -p test/types/wp5b-server-construction/tsconfig.json --noEmit",
    "test:wp5b-server": "pnpm run build && node --test test/server/wp5b-server-construction.test.mjs && pnpm run test:wp5b-server-types",
    "test:wp5b-subpaths-runtime": "pnpm run build && node --test test/packaging/wp5b-core-subpaths.test.mjs",
    "test:wp5b-subpaths-types": "pnpm exec tsc -p test/types/wp5b-core-subpaths/tsconfig.json --noEmit",
    "test:wp5b-subpaths": "pnpm run build && node --test test/packaging/wp5b-core-subpaths.test.mjs && pnpm run test:wp5b-subpaths-types",
    "test:wp5b": "pnpm run test:wp5b-client && pnpm run test:wp5b-server && pnpm run test:wp5b-subpaths",
    "conformance:run": "pnpm run build && node scripts/run-conformance-suite.mjs",
    "e2e:draft": "pnpm run build && node scripts/run-draft-e2e.mjs",
    "conformance:client-auth": "pnpm run build && node scripts/run-conformance-client-auth.mjs",
    "conformance:authorization": "node scripts/run-conformance-authorization.mjs",
    "conformance:server": "pnpm run build && node scripts/run-conformance-server.mjs",
    "generate:mcp": "node scripts/generate-mcp.mjs",
    "report:conformance": "node scripts/report-conformance-failures.mjs",
    "sources:check": "node scripts/check-source-snapshots.mjs",
    "sources:refresh": "node scripts/refresh-source-snapshot.mjs",
    "test:unit": "node scripts/run-readiness-test-suite.mjs unit",
    "test:integration": "node scripts/run-readiness-test-suite.mjs integration",
    "test:source-refresh": "node --test test/source-refresh.integration.test.mjs",
    "test:tier-operations": "node --test test/operations/tier-operations.test.mjs",
    "test:e2e": "node scripts/run-readiness-test-suite.mjs e2e",
    "test": "pnpm run verify",
    "verify": "node scripts/verify.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "peerDependencies": {
    "@effect/platform": "^0.97.0",
    "effect": "^3.22.0"
  },
  "peerDependenciesMeta": {
    "@effect/platform": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "@effect/rpc": "0.76.0"
    }
  },
  "devDependencies": {
    "@effect/platform-node": "0.108.0",
    "@effect/rpc": "0.76.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "@types/node": "^22.0.0",
    "effect": "3.22.0",
    "typescript": "^5.9.3"
  }
}
